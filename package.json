{
    "name": "obsidian-ai-commit",
    "version": "1.0.3",
    "description": "Generate commit messages via DeepSeek AI for Obsidian Git",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [
        "obsidian",
        "plugin",
        "git",
        "commit",
        "ai",
        "deepseek"
    ],
    "author": "arumata",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.0.0",
        "esbuild": "^0.24.0",
        "obsidian": "latest",
        "tslib": "^2.6.0",
        "typescript": "^5.4.0"
    }
}
